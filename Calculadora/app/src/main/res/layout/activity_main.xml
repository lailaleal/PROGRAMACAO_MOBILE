<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calc_background"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- VISOR LCD - Proporcional a 25% da altura da tela -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.25"
        app:cardBackgroundColor="@color/lcd_background"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/tvExpression"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="sin(π/2) + log(100)"
                android:textColor="@color/lcd_text_secondary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="3"
                android:textColor="@color/lcd_text_primary"
                android:textSize="54sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- GRADE DE BOTÕES - Proporcional a 75% da altura da tela -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.75"
        android:columnCount="4"
        android:rowCount="7"
        android:padding="1dp">

        <!-- Linha 1 -->
        <Button android:id="@+id/btnSin" style="@style/calcFunction" android:text="sin"/>
        <Button android:id="@+id/btnCos" style="@style/calcFunction" android:text="cos"/>
        <Button android:id="@+id/btnTan" style="@style/calcFunction" android:text="tan"/>
        <Button android:id="@+id/btnLog" style="@style/calcFunction" android:text="log"/>

        <!-- Linha 2 -->
        <Button android:id="@+id/btnSqrt" style="@style/calcFunction" android:text="√"/>
        <Button android:id="@+id/btnSquare" style="@style/calcFunction" android:text="x²"/>
        <Button android:id="@+id/btnPi" style="@style/calcFunction" android:text="π"/>
        <Button android:id="@+id/btnOpen" style="@style/calcFunction" android:text="("/>

        <!-- Linha 3 -->
        <Button android:id="@+id/btnDel" style="@style/calcSpecial" android:text="DEL"/>
        <Button android:id="@+id/btnClear" style="@style/calcSpecial" android:text="AC"/>
        <Button android:id="@+id/btnClose" style="@style/calcFunction" android:text=")"/>
        <Button android:id="@+id/btnDiv" style="@style/calcFunction" android:text="÷"/>

        <!-- Linha 4 -->
        <Button android:id="@+id/btn7" style="@style/calcNumber" android:text="7"/>
        <Button android:id="@+id/btn8" style="@style/calcNumber" android:text="8"/>
        <Button android:id="@+id/btn9" style="@style/calcNumber" android:text="9"/>
        <Button android:id="@+id/btnMul" style="@style/calcFunction" android:text="×"/>

        <!-- Linha 5 -->
        <Button android:id="@+id/btn4" style="@style/calcNumber" android:text="4"/>
        <Button android:id="@+id/btn5" style="@style/calcNumber" android:text="5"/>
        <Button android:id="@+id/btn6" style="@style/calcNumber" android:text="6"/>
        <Button android:id="@+id/btnSub" style="@style/calcFunction" android:text="-"/>

        <!-- Linha 6 -->
        <Button android:id="@+id/btn1" style="@style/calcNumber" android:text="1"/>
        <Button android:id="@+id/btn2" style="@style/calcNumber" android:text="2"/>
        <Button android:id="@+id/btn3" style="@style/calcNumber" android:text="3"/>
        <Button android:id="@+id/btnAdd" style="@style/calcFunction" android:text="+"/>

        <!-- Linha 7 -->
        <Button android:id="@+id/btn0" style="@style/calcNumber" android:text="0"/>
        <Button android:id="@+id/btnDot" style="@style/calcNumber" android:text="."/>
        <Button android:id="@+id/btnExp" style="@style/calcNumber" android:text="EXP" android:textSize="14sp"/>
        <Button android:id="@+id/btnEquals" style="@style/calcEquals" android:text="="/>

    </GridLayout>

</LinearLayout>
