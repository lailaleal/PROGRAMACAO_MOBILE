<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- CARD CONTAINER -->
    <FrameLayout
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- FRENTE DO CARTÃO -->
        <LinearLayout
            android:id="@+id/cardFront"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_cartao"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BANDEIRA -->
            <ImageView
                android:id="@+id/imgBandeira"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:visibility="gone"
                android:contentDescription="Bandeira do cartão"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvNumeroCartao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0000 0000 0000 0000"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvNomeCartao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOME SOBRENOME"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/tvValidadeCartao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MM/AA"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- VERSO DO CARTÃO -->
        <LinearLayout
            android:id="@+id/cardBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_cartao"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Tarja Magnética -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#000000"
                android:layout_marginTop="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:paddingEnd="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF"
                    android:layout_marginStart="16dp"/>

                <TextView
                    android:id="@+id/tvCvvCartao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="000"
                    android:textColor="#000000"
                    android:background="#FFFFFF"
                    android:padding="5dp"
                    android:textStyle="italic"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- CAMPO NÚMERO -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNumero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNumeroCartao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número do Cartão"
            android:inputType="number"
            android:maxLength="19"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- CAMPO NOME -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilNumero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome no Cartão"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- CAMPO VALIDADE -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilValidade"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilNome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etValidade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="MM/AA"
            android:inputType="date"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- CAMPO CVV -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCvv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilValidade"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCvv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="CVV"
            android:inputType="numberPassword"
            android:maxLength="3"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTÃO SALVAR -->
    <Button
        android:id="@+id/btnValidar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Salvar Cartão"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/tilCvv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>